{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "tavily-search": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-tavily"
      ],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "C:\\Users\\renre\\Smart_LMS"
      ]
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "${CONTEXT7_API_KEY}"
      ]
    },
    "mysql": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-mysql"
      ],
      "env": {
        "MYSQL_HOST": "127.0.0.1",
        "MYSQL_PORT": "3306",
        "MYSQL_USER": "root",
        "MYSQL_PASSWORD": "",
        "MYSQL_DATABASE": "slms_db"
      }
    },
    "openapi": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-openapi"
      ],
      "env": {
        "OPENAPI_FILE": "C:\\Users\\renre\\Smart_LMS\\openapi.yaml"
      }
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-playwright"
      ]
    },
    "artisan": {
      "command": "php",
      "args": [
        "artisan"
      ]
    },
    "composer": {
      "command": "composer",
      "args": []
    },
    "http": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-http"
      ]
    },
    "n8n-mcp": {
      "type": "http",
      "url": "https://n8n.smkmustaqbal.sch.id/mcp-server/http",
      "headers": {
        "Authorization": "Bearer ${N8N_MCP_TOKEN}"
      }
    },
    "coolify-mcp": {
      "type": "http",
      "url": "http://192.168.100.112:8000/mcp",
      "headers": {
        "Authorization": "Bearer ${COOLIFY_TOKEN}"
      }
    }
  }
}
