data: {"result":{"content":[{"type":"text","text":"{\"workflow\":{\"id\":\"xRZhptq03pAwX3qR\",\"name\":\"SmartLMS Full Pipeline v2\",\"active\":false,\"isArchived\":false,\"versionId\":\"6957f806-9c85-42bc-acea-f65656c27942\",\"activeVersionId\":null,\"triggerCount\":1,\"createdAt\":\"2026-06-04T01:21:25.419Z\",\"updatedAt\":\"2026-06-05T03:21:31.380Z\",\"settings\":{\"executionOrder\":\"v1\",\"binaryMode\":\"separate\",\"callerPolicy\":\"workflowsFromSameOwner\",\"availableInMCP\":true},\"connections\":{\"ð¥ Webhook\":{\"main\":[[{\"node\":\"ð§ Get Image Binary\",\"type\":\"main\",\"index\":0}]]},\"ð§ Get Image Binary\":{\"main\":[[{\"node\":\"ð¤ Gemini Vision1\",\"type\":\"main\",\"index\":0}]]},\"ð Parse Result\":{\"main\":[[{\"node\":\"ð¤ Prepare Lookups\",\"type\":\"main\",\"index\":0}]]},\"ð¤ Prepare Lookups\":{\"main\":[[{\"node\":\"ð Google Books1\",\"type\":\"main\",\"index\":0},{\"node\":\"ð OpenLibrary1\",\"type\":\"main\",\"index\":0}]]},\"ð Merge â JSON\":{\"main\":[[{\"node\":\"â Return\",\"type\":\"main\",\"index\":0}]]},\"ð¤ Gemini Vision1\":{\"main\":[[{\"node\":\"ð Parse Result\",\"type\":\"main\",\"index\":0}]]},\"ð Google Books1\":{\"main\":[[{\"node\":\"ð Merge â JSON\",\"type\":\"main\",\"index\":0}]]},\"ð OpenLibrary1\":{\"main\":[[{\"node\":\"ð Merge â JSON\",\"type\":\"main\",\"index\":0}]]},\"Google Gemini Chat Model\":{\"ai_languageModel\":[[{\"node\":\"ð¤ Gemini Vision1\",\"type\":\"ai_languageModel\",\"index\":0}]]}},\"nodes\":[{\"parameters\":{\"httpMethod\":\"POST\",\"path\":\"smartlms-vision\",\"responseMode\":\"responseNode\",\"options\":{\"binaryPropertyName\":\"data\",\"rawBody\":true}},\"id\":\"69106257-ee34-4296-b066-b130fd43bb8d\",\"name\":\"ð¥ Webhook\",\"type\":\"n8n-nodes-base.webhook\",\"typeVersion\":2,\"position\":[-1296,672],\"webhookId\":\"b7b0629e-7e5d-4f56-8f0e-13ce8ec6b9a2\"},{\"parameters\":{\"jsCode\":\"// Get uploaded image binary data\\nconst items = $input.all();\\nconst first = items[0];\\nconst binary = first.binary;\\n\\n// Find the image field\\nconst imgKey = Object.keys(binary).find(k => k !== 'data' && (binary[k].mimeType?.startsWith('image/')))\\n  || Object.keys(binary).find(k => binary[k].mimeType?.startsWith('image/'))\\n  || Object.keys(binary)[0];\\n\\nconst img = binary[imgKey];\\nif (!img) throw new Error('No image found in webhook payload');\\n\\nreturn items.map(item => ({\\n  json: {\\n    binaryKey: imgKey,\\n    mimeType: img.mimeType || 'image/jpeg'\\n  },\\n  binary: item.binary\\n}));\"},\"id\":\"f2df64d1-e84d-4563-b44c-104498677ecd\",\"name\":\"ð§ Get Image Binary\",\"type\":\"n8n-nodes-base.code\",\"typeVersion\":2,\"position\":[-1072,672]},{\"parameters\":{\"jsCode\":\"// â ï¸ GANTI NODE DIATAS DENGAN:\\n// 1. Tambah node \\\"Google Gemini Chat Model\\\" (bukan agent)\\n// 2. Connect credential Gemini API\\n// 3. Set model: gemini-2.5-flash\\n// 4. Prompt: system message di code node ini\\n//\\n// Untuk sekarang, parse Gemini response dari node LLM\\nconst response = $input.first().json;\\nlet text = response.output || response.text || '';\\n\\n// Bersihkan markdown fences\\ntext = text.replace(/```json\\\\n?|```/g, '').trim();\\n\\nlet data = {};\\ntry {\\n  data = JSON.parse(text);\\n} catch(e) {\\n  // Coba ekstrak JSON dari text\\n  const m = text.match(/\\\\{[\\\\s\\\\S]*\\\\}/);\\n  if (m) try { data = JSON.parse(m[0]); } catch(e2) {}\\n}\\n\\nconst isbn = (data.isbn || '').replace(/[^0-9Xx]/g, '');\\n\\nreturn {\\n  isbn: isbn || null,\\n  title: data.title || null,\\n  author: data.author || null,\\n  publisher: data.publisher || null,\\n  category: data.category || null\\n};\"},\"id\":\"eefa8087-9143-436e-8347-6881d4445939\",\"name\":\"ð Parse Result\",\"type\":\"n8n-nodes-base.code\",\"typeVersion\":2,\"position\":[-640,672]},{\"parameters\":{\"jsCode\":\"const data = $input.first().json;\\nconst isbn = data.isbn;\\nconst title = data.title;\\n\\n// Get front cover from webhook\\nlet coverUrl = null;\\n\\nreturn {\\n  _gemini: data,\\n  apiCalls: [\\n    isbn ? { name: 'google', url: `https://www.googleapis.com/books/v1/volumes?q=isbn:${isbn}` } : null,\\n    isbn ? { name: 'openlib', url: `https://openlibrary.org/isbn/${isbn}.json` } : null,\\n    (!isbn && title) ? { name: 'google_title', url: `https://www.googleapis.com/books/v1/volumes?q=${encodeURIComponent('intitle:' + title)}&maxResults=1` } : null,\\n    (!isbn && title) ? { name: 'openlib_title', url: `https://openlibrary.org/search.json?title=${encodeURIComponent(title)}&limit=1` } : null,\\n  ].filter(Boolean)\\n};\"},\"id\":\"d45fa17a-bad3-454e-b0b6-c7fb9cfc01af\",\"name\":\"ð¤ Prepare Lookups\",\"type\":\"n8n-nodes-base.code\",\"typeVersion\":2,\"position\":[-448,672]},{\"parameters\":{\"jsCode\":\"// Merge: Gemini + Google Books + OpenLibrary\\nconst all = $input.all();\\nconst gemini = all[0]?.json?._gemini || {};\\nconst googleRaw = all.find(i => i.json?.items && !i.json?._gemini && !i.json?.apiCalls)?.json;\\nconst olRaw = all.find(i => (i.json?.title || i.json?.publishers) && !i.json?._gemini)?.json;\\nconst olSearch = all.find(i => i.json?.docs && !i.json?._gemini)?.json;\\n\\n// Parse Google\\nlet g = {};\\nif (googleRaw?.items?.length) {\\n  const vi = googleRaw.items[0].volumeInfo || {};\\n  g = {\\n    title: vi.title, author: (vi.authors||[]).join(', '),\\n    publisher: vi.publisher, year: vi.publishedDate ? parseInt(vi.publishedDate.substring(0,4)) : null,\\n    desc: vi.description, category: vi.categories?.[0],\\n    cover: vi.imageLinks?.thumbnail?.replace('http:','https:'), lang: vi.language\\n  };\\n}\\n\\n// Parse OpenLibrary direct\\nlet o = {};\\nif (olRaw?.title) {\\n  o = {\\n    title: olRaw.title, author: olRaw.authors?.map(a=>a.name||a).join(', '),\\n    publisher: olRaw.publishers?.[0], year: olRaw.publish_date ? parseInt(olRaw.publish_date.substring(0,4)) : null,\\n    cover: olRaw.covers?.[0] ? `https://covers.openlibrary.org/b/id/${olRaw.covers[0]}-M.jpg` : null\\n  };\\n}\\n\\n// Parse OpenLibrary search\\nif (olSearch?.docs?.length) {\\n  const d = olSearch.docs[0];\\n  o = {\\n    title: d.title || o.title, author: d.author_name?.join(', ') || o.author,\\n    publisher: d.publisher?.[0] || o.publisher, year: d.first_publish_year || o.year,\\n    cover: d.cover_i ? `https://covers.openlibrary.org/b/id/${d.cover_i}-M.jpg` : o.cover\\n  };\\n}\\n\\nconst pick = (a,b,c) => a || b || c || null;\\n\\nreturn {\\n  found: true,\\n  book: {\\n    title: pick(g.title, o.title, gemini.title) || '',\\n    author: pick(g.author, o.author, gemini.author) || '',\\n    isbn: gemini.isbn || '',\\n    publisher: pick(g.publisher, o.publisher, gemini.publisher) || '',\\n    published_year: pick(g.year, o.year, null),\\n    description: g.desc || '',\\n    category: pick(g.category, null, gemini.category) || '',\\n    cover_url: pick(g.cover, o.cover, null) || ''\\n  },\\n  sources: { google: !!Object.keys(g).filter(k=>g[k]).length, openlibrary: !!Object.keys(o).filter(k=>o[k]).length, gemini: true }\\n};\"},\"id\":\"5ac813db-8ea6-4796-bdaa-a15d781e36dd\",\"name\":\"ð Merge â JSON\",\"type\":\"n8n-nodes-base.code\",\"typeVersion\":2,\"position\":[-32,672]},{\"parameters\":{\"respondWith\":\"json\",\"responseBody\":\"={{ $json }}\",\"options\":[]},\"id\":\"a4d252d4-d81d-4b23-81ee-776512faa658\",\"name\":\"â Return\",\"type\":\"n8n-nodes-base.respondToWebhook\",\"typeVersion\":1,\"position\":[160,672]},{\"parameters\":{\"options\":{\"systemMessage\":\"Kamu adalah pustakawan AI. Analisis cover buku dan ekstrak metadata.\\n\\nBalas HANYA dengan JSON (tanpa markdown, tanpa penjelasan):\\n{\\n  \\\"isbn\\\": \\\"9786020332116 atau kosong\\\",\\n  \\\"title\\\": \\\"judul buku\\\",\\n  \\\"author\\\": \\\"nama penulis\\\",\\n  \\\"publisher\\\": \\\"nama penerbit\\\",\\n  \\\"category\\\": \\\"kategori buku\\\"\\n}\\n\\nISBN selalu diformat tanpa strip/spasi. Jika field tidak terbaca, isi string kosong \\\"\\\".\"}},\"id\":