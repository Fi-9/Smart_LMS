APP_NAME="Smart Library"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=smart_lms
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
DB_QUEUE_RETRY_AFTER=900

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
GOOGLE_BOOKS_API_KEY=
GOOGLE_BOOKS_CACHE_MINUTES=120
GOOGLE_BOOKS_CACHE_MISS_MINUTES=1
OLLAMA_BASE_URL=http://192.168.100.200:11434
OLLAMA_MODEL=qwen2.5:32b
OLLAMA_VISION_MODEL=llama3.2-vision
OLLAMA_TEXT_MODEL=qwen2.5:32b
OLLAMA_WEB_MODEL=llama3.1:latest
OLLAMA_TIMEOUT=300
OLLAMA_CONNECT_TIMEOUT=10
AI_RUNTIME_PROFILE=local-ollama
AI_SCAN_DEFAULT_MODE=auto

WEBSEARCH_ENABLED=false
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
TAVILY_TIMEOUT=15
WEBSEARCH_MAX_RESULTS=3
WEBSEARCH_ALLOWED_DOMAINS=goodreads.com,gramedia.com,mizanstore.com,bukukita.com,openlibrary.org,books.google.com
WEBSEARCH_CACHE_MINUTES=180
WEBSEARCH_CACHE_MISS_MINUTES=20
AI_COVER_WIDTH=600
AI_COVER_HEIGHT=900

VITE_APP_NAME="${APP_NAME}"
